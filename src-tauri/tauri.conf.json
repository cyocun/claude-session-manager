{
  "productName": "Claude Sessions",
  "version": "0.1.0",
  "identifier": "com.cyocun.claude-session-manager",
  "build": {
    "frontendDist": "../frontend",
    "beforeBuildCommand": "cargo build --release -p csm-mcp && install target/release/csm-mcp target/release/csm-mcp-aarch64-apple-darwin"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset:; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "Claude Sessions",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "externalBin": ["../target/release/csm-mcp"],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCRDlGQjgxREUzMTQ2RkUKUldUK1JqSGVnZnZaKzgvb3p2bHpiU0hUakc5NkVYZ2h2VGFZOXpUL0NJcEoxemNRb0dkYUE2bk4K",
      "endpoints": [
        "https://github.com/cyocun/claude-session-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
