{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "outDir": "frontend/js",
    "rootDir": "frontend/ts",
    "noEmitOnError": false,
    "allowSyntheticDefaultImports": true
  },
  "include": ["frontend/ts/**/*.ts"]
}
